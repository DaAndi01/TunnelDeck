    "Benjamin Kohler (bkohler616 fork)"
  ],
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/DaAndi01/TunnelDeck/issues"
  },
  "homepage": "https://github.com/DaAndi01/TunnelDeck#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/react-router": "5.1.20",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
